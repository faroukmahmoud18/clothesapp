{
  "compilerOptions": {
    "composite": true, // Required for project references
    "module": "CommonJS",
    "target": "ES2020",
    "moduleResolution": "node",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "dist", // This might be overridden by Electron Forge
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"] // Keep consistent if main process needs to import shared code
    }
  },
  "include": ["webpack.main.config.ts", "webpack.renderer.config.ts", "webpack.rules.ts", "webpack.plugins.ts", "forge.config.ts", "src/index.ts", "src/preload.ts"] // Files specific to main/build process
}
